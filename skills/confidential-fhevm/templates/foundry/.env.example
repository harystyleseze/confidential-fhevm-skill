# Repo-root .env.example — copy to `.env.local` (gitignored) and fill in.
# Consumed by scripts/deploy-sepolia.sh.

# Sepolia RPC endpoint. Free options:
#   https://eth-sepolia.g.alchemy.com/v2/<ALCHEMY_KEY>
#   https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_RPC_URL=

# Private key of the deployer wallet (0x-prefixed). Must hold ≥0.05 Sepolia ETH.
# Faucet: https://www.alchemy.com/faucets/ethereum-sepolia
DEPLOYER_PRIVATE_KEY=

# Optional: Etherscan V2 API key. One key works for all chains (post-May-2025).
# Without this, the deploy script skips verification but Sourcify still indexes.
ETHERSCAN_API_KEY=
